<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="EDIT TRACK TAGS"
            android:textColor="@color/dark_subtext"
            android:textSize="10sp"
            android:letterSpacing="0.14"
            android:layout_marginBottom="16dp"/>

        <!-- Track info preview -->
        <LinearLayout
            android:id="@+id/card_track_preview"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card_border"
            android:padding="14dp"
            android:layout_marginBottom="24dp">

            <ImageView
                android:id="@+id/iv_id3_art"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_music_note"
                android:background="@drawable/bg_radius_12"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="14dp">

                <TextView android:id="@+id/tv_id3_title" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/dark_text" android:textSize="14sp" android:textStyle="bold" android:ellipsize="end" android:maxLines="1"/>
                <TextView android:id="@+id/tv_id3_artist_album" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/dark_subtext" android:textSize="12sp" android:ellipsize="end" android:maxLines="1"/>

            </LinearLayout>

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="end">
                <TextView android:id="@+id/tv_id3_duration" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/dark_subtext" android:textSize="11sp" android:fontFamily="monospace"/>
                <TextView android:id="@+id/tv_id3_genre" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/purple_light" android:textSize="11sp" android:textStyle="bold"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Song Title field -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="♪ SONG TITLE" android:textColor="@color/dark_subtext" android:textSize="10sp" android:letterSpacing="0.12" android:layout_marginBottom="6dp"/>
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/dark_text"
                android:textSize="14sp"
                android:inputType="text"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Artist field -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="◉ ARTIST" android:textColor="@color/dark_subtext" android:textSize="10sp" android:letterSpacing="0.12" android:layout_marginBottom="6dp"/>
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_artist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/dark_text"
                android:textSize="14sp"
                android:inputType="text"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Album field -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="💿 ALBUM" android:textColor="@color/dark_subtext" android:textSize="10sp" android:letterSpacing="0.12" android:layout_marginBottom="6dp"/>
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_album"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/dark_text"
                android:textSize="14sp"
                android:inputType="text"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Genre field -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="🎭 GENRE" android:textColor="@color/dark_subtext" android:textSize="10sp" android:letterSpacing="0.12" android:layout_marginBottom="6dp"/>
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_genre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/dark_text"
                android:textSize="14sp"
                android:inputType="text"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Year field -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="📅 YEAR" android:textColor="@color/dark_subtext" android:textSize="10sp" android:letterSpacing="0.12" android:layout_marginBottom="6dp"/>
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_year"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/dark_text"
                android:textSize="14sp"
                android:inputType="number"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Action buttons -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">

            <Button
                android:id="@+id/btn_reset_tags"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="10dp"
                android:text="↺  Reset"
                android:textSize="13sp"/>

            <Button
                android:id="@+id/btn_save_tags"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="2"
                android:text="✓  Save Tags"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/bg_circle_purple_gradient"/>

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/session_only"
            android:textColor="@color/dark_subtext"
            android:textSize="11sp"
            android:gravity="center"
            android:layout_marginTop="10dp"/>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
