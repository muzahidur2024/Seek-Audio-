<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/dark_bg">

    <!-- Mini header with current track + seek -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="@color/dark_surface">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">

            <ImageView android:id="@+id/iv_lyrics_art" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_music_note" android:background="@drawable/bg_radius_12"/>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                <TextView android:id="@+id/tv_lyrics_title" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/dark_text" android:textSize="15sp" android:textStyle="bold" android:ellipsize="end" android:maxLines="1"/>
                <TextView android:id="@+id/tv_lyrics_artist" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/dark_subtext" android:textSize="12sp"/>
            </LinearLayout>

            <ImageButton android:id="@+id/btn_lyrics_play_pause" android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_circle_purple" android:src="@drawable/ic_play" android:padding="10dp"/>

        </LinearLayout>

        <SeekBar android:id="@+id/seek_lyrics" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:progressTint="@color/purple_primary" android:progressBackgroundTint="@color/dark_border"/>

        <!-- Sync offset row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SYNC" android:textColor="@color/dark_text" android:textSize="11sp" android:textStyle="bold" android:letterSpacing="0.08" android:layout_marginEnd="8dp"/>
            <Button android:id="@+id/btn_offset_minus" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="wrap_content" android:layout_height="30dp" android:minWidth="52dp" android:text="-0.5s" android:textSize="11sp" android:layout_marginEnd="8dp"/>
            <TextView android:id="@+id/tv_offset" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="+0.0s" android:textColor="@color/purple_light" android:textSize="12sp" android:textStyle="bold" android:fontFamily="monospace" android:layout_marginEnd="8dp"/>
            <Button android:id="@+id/btn_offset_plus" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="wrap_content" android:layout_height="30dp" android:minWidth="52dp" android:text="+0.5s" android:textSize="11sp"/>
        </LinearLayout>

    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Lyrics scroll -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_lyrics"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingVertical="16dp"
            android:paddingHorizontal="20dp"
            android:clipToPadding="false"
            android:scrollbars="none"/>

        <LinearLayout
            android:id="@+id/layout_lyrics_state"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">

            <ProgressBar
                android:id="@+id/progress_lyrics"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tv_no_lyrics"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/no_lyrics"
                android:textColor="@color/dark_subtext"
                android:textAlignment="center"
                android:gravity="center"
                android:visibility="gone"/>
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
