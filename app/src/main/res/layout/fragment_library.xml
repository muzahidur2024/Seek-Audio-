<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/dark_bg">

    <!-- Search bar -->
    <androidx.appcompat.widget.SearchView
        android:id="@+id/search_view"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        app:iconifiedByDefault="false"
        app:queryHint="@string/search_hint"
        app:searchIcon="@drawable/ic_search"
        android:background="@drawable/bg_search_field"/>

    <!-- Filter tabs -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/tab_all"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/tab_all"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.Chip.Choice"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/tab_liked"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/tab_liked"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.Chip.Choice"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/tab_recent"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/tab_recent"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.Chip.Choice"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/tab_most_played"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/tab_most_played"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.Chip.Choice"/>

        </LinearLayout>

    </HorizontalScrollView>

    <!-- Song count label -->
    <TextView
        android:id="@+id/tv_song_count"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:text="0 songs"
        android:textColor="@color/dark_subtext"
        android:textSize="10sp"
        android:letterSpacing="0.14"/>

    <!-- Songs list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_songs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="8dp"
        android:clipToPadding="false"
        android:scrollbars="none"/>

    <!-- Empty state -->
    <TextView
        android:id="@+id/tv_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/no_songs_found"
        android:textColor="@color/dark_subtext"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"/>

</LinearLayout>
