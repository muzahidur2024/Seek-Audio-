<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:gravity="center_vertical"
    android:background="@drawable/bg_card_border" android:padding="14dp" android:layout_marginBottom="10dp">

    <TextView android:id="@+id/tv_feature_icon"
        android:layout_width="44dp" android:layout_height="44dp"
        android:gravity="center" android:textSize="22sp"
        android:background="@drawable/bg_radius_12"/>

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
        <TextView android:id="@+id/tv_feature_title"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/dark_text" android:textSize="13sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tv_feature_desc"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/dark_subtext" android:textSize="11sp" android:layout_marginTop="2dp"/>
    </LinearLayout>
</LinearLayout>
