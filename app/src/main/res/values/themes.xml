<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SeekAudio" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_primary</item>
        <item name="colorPrimaryVariant">@color/purple_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/purple_light</item>
        <item name="colorOnSecondary">@color/dark_bg</item>
        <item name="colorSurface">@color/dark_surface</item>
        <item name="colorOnSurface">@color/dark_text</item>
        <item name="android:colorBackground">@color/dark_bg</item>
        <item name="colorOnBackground">@color/dark_text</item>
        <item name="android:statusBarColor">@color/dark_bg</item>
        <item name="android:navigationBarColor">@color/dark_surface</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="Theme.SeekAudio.Driving" parent="Theme.SeekAudio">
        <item name="android:colorBackground">@color/black</item>
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:navigationBarColor">@color/black</item>
    </style>

    <style name="Theme.SeekAudio.BottomSheet" parent="Theme.MaterialComponents.DayNight.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.SeekAudio.BottomSheet</item>
    </style>

    <style name="Widget.SeekAudio.BottomSheet" parent="Widget.MaterialComponents.BottomSheet">
        <item name="android:background">@color/dark_surface</item>
    </style>
</resources>
